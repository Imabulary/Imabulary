{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../openapi/swagger.generated.yaml",
        "outDir": "dist/openapi",
        "watchAssets": true
      }
    ],
    "plugins": ["@nestjs/swagger"],
    "watchAssets": true
  }
}
