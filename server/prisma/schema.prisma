generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cards {
  id                     String         @id @default(uuid()) @db.VarChar()
  word                   String         @db.VarChar()
  phrase                 String
  explanation            String?
  speech_part            String?        @db.VarChar()
  translated_word        String         @db.VarChar()
  translated_phrase      String
  translated_explanation String?
  target_language        String         @db.VarChar()
  source_language        String         @db.VarChar()
  image_url              String         @db.VarChar()
  image_name             String?
  is_regenerated         Boolean        @default(false)
  audio_url              String?        @db.VarChar()
  audio_name             String?
  quizStatusId           String
  userId                 String?        @db.VarChar()
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  isTouched              Boolean        @default(false)
  user                   Users?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets                   Sets[]
  CardsOnSets            CardsOnSets[]
  Feedback               Feedback?
  QuizStatus             QuizCardStatus @relation(fields: [quizStatusId], references: [id])
}

model Users {
  id         String     @id @default(uuid()) @db.VarChar()
  externalId String     @unique
  email      String?
  flashcards Cards[]
  sets       Sets[]
  feedbacks  Feedback[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  Wallet     Wallet?
}

model Sets {
  id          String        @id @default(uuid()) @db.VarChar()
  name        String        @db.VarChar()
  description String?       @db.Text()
  isFinished  Boolean       @default(false)
  user        Users?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?       @db.VarChar()
  flashcards  Cards[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  CardsOnSets CardsOnSets[]
}

model CardsOnSets {
  set         Sets     @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId       String
  flashcard   Cards    @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  flashcardId String
  createdAt   DateTime @default(now())

  @@id([setId, flashcardId])
}

model Wallet {
  id      String       @id @default(uuid()) @db.VarChar()
  userId  String       @unique @db.VarChar()
  status  WalletStatus @default(ACTIVE)
  balance Float        @default(0.0)
  user    Users        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id            String             @id @default(uuid()) @db.VarChar()
  userId        String?            @db.VarChar()
  cardId        String?            @unique @db.VarChar()
  isAppropriate Boolean?           @default(false)
  text          String?
  category      FeedbackCategory[] @relation("card_feedbacks_categories")
  card          Cards?             @relation(fields: [cardId], references: [id])
  metadata      Json?
  user          Users?             @relation(fields: [userId], references: [id])
}

model FeedbackCategory {
  id       String     @id @default(uuid()) @db.VarChar()
  name     String
  slug     String?    @unique
  meaning  String
  feedback Feedback[] @relation("card_feedbacks_categories")
}

enum WalletStatus {
  ACTIVE
  INACTIVE
}

model QuizCardStatus {
  id    String  @id @default(uuid()) @db.VarChar()
  name  String  @unique
  Cards Cards[]
}
