generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cards {
  id                     String        @id @default(uuid()) @db.VarChar()
  word                   String        @db.VarChar()
  phrase                 String
  file_name              String?
  explanation            String?
  speech_part            String?       @db.VarChar()
  translated_word        String        @db.VarChar()
  translated_phrase      String
  translated_explanation String?
  target_language        String        @db.VarChar()
  source_language        String        @db.VarChar()
  image_url              String        @db.VarChar()
  audio_url              String?       @db.VarChar()
  audio_name             String?
  user                   Users?        @relation(fields: [userId], references: [id])
  userId                 String?       @db.VarChar()
  sets                   Sets[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  CardsOnSets            CardsOnSets[]
  Feedback               Feedback?
}

model Users {
  id         String   @id @default(uuid()) @db.VarChar()
  externalId String   @unique
  email      String   @unique
  flashcards Cards[]
  sets       Sets[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Wallet     Wallet?
}

model Sets {
  id          String        @id @default(uuid()) @db.VarChar()
  name        String        @db.VarChar()
  description String?       @db.Text()
  user        Users?        @relation(fields: [userId], references: [id])
  userId      String?       @db.VarChar()
  flashcards  Cards[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  CardsOnSets CardsOnSets[]
}

model CardsOnSets {
  set         Sets     @relation(fields: [setId], references: [id])
  setId       String
  flashcard   Cards    @relation(fields: [flashcardId], references: [id])
  flashcardId String
  createdAt   DateTime @default(now())

  @@id([setId, flashcardId])
}

model Wallet {
  id       String       @id @default(uuid()) @db.VarChar()
  userId   String       @unique @db.VarChar()
  status   WalletStatus @default(ACTIVE)
  balance  Float        @default(0.0)
  user     Users        @relation(fields: [userId], references: [id])
  Awards   Awards?
  Cashback Cashback?
}

model Awards {
  id            String   @id @default(uuid()) @db.VarChar()
  walletId      String   @unique @db.VarChar()
  lastAwardedAt DateTime @default(now())
  streekLevel   Int      @default(1)
  streekCount   Int      @default(0)
  award         Float    @default(1.0)
  wallet        Wallet   @relation(fields: [walletId], references: [id])
}

model Cashback {
  id       String @id @default(uuid()) @db.VarChar()
  walletId String @unique @db.VarChar()
  level    Int    @default(1)
  refund   Float  @default(0.1)
  wallet   Wallet @relation(fields: [walletId], references: [id])
}

model Feedback {
  id            String   @id @default(uuid()) @db.VarChar()
  cardId        String   @unique @db.VarChar()
  isAppropriate Boolean?
  textFeedback  String?
  card          Cards    @relation(fields: [cardId], references: [id])
}

enum WalletStatus {
  ACTIVE
  INACTIVE
}
