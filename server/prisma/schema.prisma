generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cards {
  id                String        @id @default(uuid()) @db.VarChar()
  word              String        @db.VarChar()
  phrase            String
  translated_word   String        @db.VarChar()
  translated_phrase String
  target_language   String        @db.VarChar()
  source_language   String        @db.VarChar()
  image_url         String        @db.VarChar()
  user              Users?        @relation(fields: [userId], references: [id])
  userId            String?       @db.VarChar()
  sets              Sets[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  CardsOnSets       CardsOnSets[]
}

model Users {
  id         String   @id @default(uuid()) @db.VarChar()
  externalId String   @unique
  email      String   @unique
  flashcards Cards[]
  sets       Sets[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Wallet     Wallet?
}

model Sets {
  id          String        @id @default(uuid()) @db.VarChar()
  name        String        @db.VarChar()
  description String?       @db.Text()
  user        Users?        @relation(fields: [userId], references: [id])
  userId      String?       @db.VarChar()
  flashcards  Cards[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  CardsOnSets CardsOnSets[]
}

model CardsOnSets {
  set         Sets     @relation(fields: [setId], references: [id])
  setId       String
  flashcard   Cards    @relation(fields: [flashcardId], references: [id])
  flashcardId String
  createdAt   DateTime @default(now())

  @@id([setId, flashcardId])
}

model Wallet {
  id      String  @id @default(uuid()) @db.VarChar()
  userId  String  @unique @db.VarChar()
  status  String  @default("active")
  balance Float   @default(0.0)
  user    Users   @relation(fields: [userId], references: [id])
  Awards  Awards?
}

model Awards {
  id            String    @id @default(uuid()) @db.VarChar()
  walletId      String    @unique @db.VarChar()
  lastAwardedAt String?
  streekLevel   Int       @default(1)
  streekCount   Int       @default(0)
  award         Float     @default(1.0)
  wallet        Wallet    @relation(fields: [walletId], references: [id])
}
